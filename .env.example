# ─── App ───────────────────────────────────────────────
SECRET_KEY=replace-with-a-secure-random-string
DEBUG=false

# ─── Database ──────────────────────────────────────────
DB_USER=civixa
DB_PASS=civixa
DB_HOST=localhost
DB_PORT=5432
DB_NAME=civixa_db

# ─── Redis / Celery ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Ollama (local LLM — free, no API key needed) ──────
# Pull models: ollama pull mistral  |  ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=120

# ─── Whisper (local speech-to-text) ────────────────────
# pip install faster-whisper   (recommended, runs on CPU)
WHISPER_CPP_MODEL=base

# ─── Twilio (WhatsApp) ─────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── AWS S3 (optional — leave blank for local storage) ─
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-south-1

# ─── Mapbox ────────────────────────────────────────────
MAPBOX_TOKEN=

# ─── Frontend ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_USE_MOCK_API=true
