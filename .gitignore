# ══════════════════════════════════════════════════════════════════════════════
# CivIxa Public Insights — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
nosetests.xml

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# Ruff / linters
.ruff_cache/

# ─── Node / Next.js ───────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Next.js build outputs
.next/
out/

# Turbo
.turbo/

# ─── Environment files ────────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Keep example files (no secrets)
!.env.example
!.env.local.example

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.suo
*.user

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Docker / infra ───────────────────────────────────────────────────────────
infra/pgdata/
pgdata/

# ─── Uploads / media ─────────────────────────────────────────────────────────
apps/api/uploads/
uploads/
media/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
celerybeat-schedule
celerybeat.pid

# ─── Database files ───────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ─── AI model cache ───────────────────────────────────────────────────────────
.cache/
sentence_transformers/

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.map
tmp/
temp/
