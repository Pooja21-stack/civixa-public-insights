# ── CivIxa Web — local environment ───────────────────────────────────────────
#
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real secrets.

# ── API backend ──────────────────────────────────────────────────────────────
# URL of the running FastAPI backend.
# Default: http://localhost:8000 (uvicorn local dev server)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Mock API toggle ───────────────────────────────────────────────────────────
# Set to "false" to route all API calls to the real FastAPI backend above.
# Set to "true" (or omit) to use local mock data — no backend needed.
#
# Quick-start:
#   NEXT_PUBLIC_USE_MOCK_API=true    ← frontend demo, no backend
#   NEXT_PUBLIC_USE_MOCK_API=false   ← full stack, backend must be running
NEXT_PUBLIC_USE_MOCK_API=true

# ── Mapbox ────────────────────────────────────────────────────────────────────
# Free token from https://account.mapbox.com/access-tokens/
# Without this the demand heatmap shows a placeholder message.
NEXT_PUBLIC_MAPBOX_TOKEN=
