# Mapbox token — get a free one at https://account.mapbox.com/access-tokens/
# Without this, the heatmap shows a placeholder. Everything else works fine.
NEXT_PUBLIC_MAPBOX_TOKEN=

# API URL — leave blank while USE_MOCK_API=true in src/lib/flags.ts
# Set this to http://localhost:8000 when the backend is running
NEXT_PUBLIC_API_URL=
